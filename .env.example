VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_REGION=asia-southeast2

# Optional HTTPS endpoint if you do not deploy a callable Firebase Function named "chatbot".
VITE_CHATBOT_FUNCTION_URL=

# Optional Firebase Data Connect (Cloud SQL/PostgreSQL) connector.
VITE_FIREBASE_DATACONNECT_LOCATION=asia-southeast2
VITE_FIREBASE_DATACONNECT_SERVICE_ID=
VITE_FIREBASE_DATACONNECT_CONNECTOR_ID=

# Optional local Data Connect emulator.
VITE_FIREBASE_DATACONNECT_EMULATOR_HOST=
VITE_FIREBASE_DATACONNECT_EMULATOR_PORT=9399

# Cloudinary media uploads.
# CLOUDINARY_URL and CLOUDINARY_API_SECRET must only be configured as server/Vercel environment variables.
VITE_CLOUDINARY_CLOUD_NAME=dyjeto09g
VITE_CLOUDINARY_API_KEY=
CLOUDINARY_CLOUD_NAME=dyjeto09g
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=
