VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FUNCTIONS_REGION=asia-southeast2

# Optional HTTPS endpoint if you do not deploy a callable Firebase Function named "chatbot".
# Defaults to /api/chatbot on Vercel.
VITE_CHATBOT_FUNCTION_URL=

# Server-only chatbot AI keys. Do not expose these with the VITE_ prefix.
# CHATBOT_PROVIDER can be auto, gemini, openai, or copilot.
CHATBOT_PROVIDER=auto
CHATBOT_PROVIDER_ORDER=gemini,openai,copilot
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=chat-latest
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4.1
COPILOT_MODEL=openai/gpt-4.1

# Optional Firebase Data Connect (Cloud SQL/PostgreSQL) connector.
VITE_FIREBASE_DATACONNECT_LOCATION=asia-southeast2
VITE_FIREBASE_DATACONNECT_SERVICE_ID=
VITE_FIREBASE_DATACONNECT_CONNECTOR_ID=

# Optional local Data Connect emulator.
VITE_FIREBASE_DATACONNECT_EMULATOR_HOST=
VITE_FIREBASE_DATACONNECT_EMULATOR_PORT=9399

# Cloudinary media uploads.
# CLOUDINARY_URL and CLOUDINARY_API_SECRET must only be configured as server/Vercel environment variables.
VITE_CLOUDINARY_CLOUD_NAME=dyjeto09g
VITE_CLOUDINARY_API_KEY=
CLOUDINARY_CLOUD_NAME=dyjeto09g
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# Newsletter email sender. RESEND_API_KEY and sender email are server-only.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL="PC IPNU IPPNU Kota Bekasi <noreply@yourdomain.com>"
NEWSLETTER_REPLY_TO=
VITE_NEWSLETTER_SEND_URL=
